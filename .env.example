# ========================
# App
# ========================
APP_ENV=development
APP_PORT=8080
JWT_SECRET=change_me_to_a_long_random_secret_key
JWT_EXPIRE_HOURS=24

# ========================
# Database
# ========================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lunchorder
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable

# ========================
# Frontend
# ========================
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws

# ========================
# Upload (file storage)
# ========================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5
