# ⚠️  KHÔNG commit file này lên git!
# Đây là template - hãy điền giá trị thật và apply thủ công,
# hoặc dùng External Secrets / Sealed Secrets trong môi trường thật.
#
# Lệnh tạo Secret từ CLI (recommended):
#   kubectl create secret generic lunchorder-secrets \
#     --namespace=lunchorder \
#     --from-literal=DB_PASSWORD='your-strong-password' \
#     --from-literal=JWT_SECRET='your-256-bit-secret' \
#     --dry-run=client -o yaml | kubectl apply -f -
#
# Giá trị phải được base64 encode:
#   echo -n "your-value" | base64

apiVersion: v1
kind: Secret
metadata:
  name: lunchorder-secrets
  namespace: lunchorder
  labels:
    app.kubernetes.io/name: lunchorder
type: Opaque
data:
  # base64("your-strong-postgres-password")
  DB_PASSWORD: eW91ci1zdHJvbmctcG9zdGdyZXMtcGFzc3dvcmQ=
  # base64("your-256-bit-jwt-secret-key-change-in-production")
  JWT_SECRET: eW91ci0yNTYtYml0LWp3dC1zZWNyZXQta2V5LWNoYW5nZS1pbi1wcm9kdWN0aW9u

---
# Secret riêng cho PostgreSQL init
apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: lunchorder
  labels:
    app.kubernetes.io/name: lunchorder
type: Opaque
data:
  # base64("your-strong-postgres-password") - phải khớp với DB_PASSWORD ở trên
  POSTGRES_PASSWORD: eW91ci1zdHJvbmctcG9zdGdyZXMtcGFzc3dvcmQ=
